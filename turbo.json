{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "start": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "API_BIND_HOST",
        "NODE_ENV",
        "WEB_BIND_HOST",
        "WEB_TLS_CERT_PATH",
        "WEB_TLS_KEY_PATH"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "API_BIND_HOST",
        "NODE_ENV",
        "WEB_BIND_HOST",
        "WEB_TLS_CERT_PATH",
        "WEB_TLS_KEY_PATH"
      ]
    }
  }
}
