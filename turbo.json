{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "ADMIN_PORT",
        "API_PORT",
        "WEB_PORT",
        "NODE_ENV",
        "PROCESS_MANAGER"
      ]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": ["NODE_ENV"]
    },
    "start": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "ADMIN_PORT",
        "API_PORT",
        "WEB_PORT",
        "NODE_ENV",
        "PROCESS_MANAGER"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "update": {
      "cache": false,
      "persistent": true
    }
  }
}
