{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "start": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["MAKE_LOCALLY_ACCESSIBLE", "NODE_ENV"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["MAKE_LOCALLY_ACCESSIBLE", "NODE_ENV"]
    }
  }
}
