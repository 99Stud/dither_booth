API_PORT=3001
WEB_PORT=3000
API_BIND_HOST=127.0.0.1
# Optional: override IP stored in .local/tls/booth-manifest.json
# WEB_PUBLIC_IP=192.168.1.42
WEB_TLS_CERT_PATH=.local/tls/booth-cert.pem
WEB_TLS_KEY_PATH=.local/tls/booth-key.pem
DB_FILE_NAME=./data/dither-booth.sqlite

# Raspberry Pi / Linux kiosk: use system Chromium instead of Puppeteer's cached Chrome-for-Testing binary.
# After: sudo apt install -y chromium
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

