{
  "name": "@dither-booth/api",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "imports": {
    "#*": "./src/*.ts"
  },
  "exports": {
    "./router.types": "./src/lib/router/router.types.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "cert:generate": "bun scripts/generate-local-cert.ts",
    "cert:clean": "bun scripts/clean-local-cert.ts",
    "cert:caroot": "mkcert -CAROOT",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/db/db.migrate.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "check-types": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@dither-booth/logging": "workspace:*",
    "@dither-booth/ports": "workspace:*",
    "@node-escpos/core": "0.6.0",
    "@node-escpos/usb-adapter": "0.3.1",
    "@opendisplay/epaper-dithering": "2.2.1",
    "@trpc/server": "11.17.0",
    "drizzle-orm": "0.45.2",
    "puppeteer": "24.42.0",
    "sharp": "0.34.5",
    "zod": "4.4.2"
  },
  "devDependencies": {
    "@types/bun": "1.3.13",
    "drizzle-kit": "0.31.10"
  }
}
