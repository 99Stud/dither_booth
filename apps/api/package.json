{
  "name": "@dither-booth/api",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "imports": {
    "#*": "./src/*"
  },
  "exports": {
    "./appRouter": "./src/appRouter.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/db/migrate.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt .",
    "check-types": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@dither-booth/ports": "workspace:*",
    "@node-escpos/core": "0.6.0",
    "@node-escpos/usb-adapter": "0.3.1",
    "@opendisplay/epaper-dithering": "2.2.1",
    "@trpc/server": "11.16.0",
    "drizzle-orm": "0.45.2",
    "puppeteer": "24.40.0",
    "sharp": "0.34.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "drizzle-kit": "0.31.10"
  },
  "peerDependencies": {
    "typescript": "5.9.3"
  }
}
