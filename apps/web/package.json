{
  "name": "@dither-booth/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt .",
    "check-types": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "@dither-booth/api": "workspace:*",
    "@dither-booth/ports": "workspace:*",
    "@tanstack/react-router": "1.168.8",
    "@tanstack/react-router-devtools": "1.166.11",
    "@trpc/client": "11.16.0",
    "bun-plugin-tailwind": "0.1.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "1.7.0",
    "next-themes": "0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "4.1.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
