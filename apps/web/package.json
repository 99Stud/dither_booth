{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "start": "NODE_ENV=production bun src/index.ts",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --check",
    "format:fix": "oxfmt .",
    "init-oxfmt": "oxfmt -c oxfmt.config.ts"
  },
  "dependencies": {
    "bun-plugin-tailwind": "0.1.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "4.2.2"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0"
  }
}
