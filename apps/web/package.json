{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot --port 4098 src/index.ts",
    "build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "start": "NODE_ENV=production bun src/index.ts",
    "lint": "cd ../.. && oxlint .",
    "lint:fix": "cd ../.. && oxlint --fix .",
    "format": "cd ../.. && oxfmt --check .",
    "format:fix": "cd ../.. && oxfmt ."
  },
  "dependencies": {
    "@trpc/client": "^11.13.4",
    "bun-plugin-tailwind": "0.1.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "4.2.2"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
