{
  "name": "@dither-booth/admin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#*": "./src/*.tsx"
  },
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "build": "tsc --noEmit -p tsconfig.json && bun scripts/build.ts",
    "start": "bun ./dist/server.js",
    "update": "bun update -i",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "check-types": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@dither-booth/api": "workspace:*",
    "@dither-booth/browser-server": "workspace:*",
    "@dither-booth/logging": "workspace:*",
    "@dither-booth/ports": "workspace:*",
    "@dither-booth/shared": "workspace:*",
    "@dither-booth/ui": "workspace:*",
    "@tanstack/react-form": "1.33.0",
    "@tanstack/react-query": "5.101.1",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-router-devtools": "1.167.0",
    "@trpc/client": "11.18.0",
    "@trpc/tanstack-react-query": "11.18.0",
    "clsx": "2.1.1",
    "date-fns": "4.4.0",
    "lucide-react": "1.21.0",
    "pm2": "7.0.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sonner": "2.0.7",
    "tailwindcss": "4.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@dither-booth/typescript-config": "workspace:*",
    "@types/bun": "1.3.14",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "bun-plugin-tailwind": "0.1.2"
  }
}
