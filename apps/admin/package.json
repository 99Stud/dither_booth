{
  "name": "@dither-booth/admin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#*": "./src/*.tsx"
  },
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "build": "tsc --noEmit -p tsconfig.json && bun scripts/build.ts",
    "start": "bun ./dist/server.js",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "check-types": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@dither-booth/browser-server": "workspace:*",
    "@dither-booth/logging": "workspace:*",
    "@dither-booth/ports": "workspace:*",
    "@dither-booth/ui": "workspace:*",
    "@tanstack/react-form": "1.29.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwindcss": "4.2.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
