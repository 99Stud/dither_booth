{
  "name": "@dither-booth/shared",
  "private": true,
  "type": "module",
  "imports": {
    "#browser/*": "./src/browser/*.ts",
    "#internal/*": "./src/internal/*.ts",
    "#isomorphic/*": "./src/isomorphic/*.ts",
    "#server/*": "./src/server/*.ts"
  },
  "exports": {
    "./async": "./src/isomorphic/async.ts",
    "./browser/blob": "./src/browser/blob.ts",
    "./browser/image": "./src/browser/image.ts",
    "./browser/receipt-viewer": "./src/browser/receipt-viewer.ts",
    "./browser/storage": "./src/browser/storage.ts",
    "./browser/trpc-client": "./src/browser/trpc-client.ts",
    "./errors": "./src/isomorphic/errors.ts",
    "./formatting": "./src/isomorphic/formatting.ts",
    "./healthz": "./src/isomorphic/healthz.ts",
    "./id": "./src/isomorphic/id.ts",
    "./printing": "./src/isomorphic/printing.ts",
    "./routes": "./src/isomorphic/routes.ts",
    "./runtime": "./src/isomorphic/runtime.ts",
    "./server/paths": "./src/server/paths.ts",
    "./server/runtime": "./src/server/runtime.ts",
    "./styles": "./src/isomorphic/styles.ts",
    "./trpc-proxy": "./src/isomorphic/trpc-proxy.ts"
  },
  "scripts": {
    "update": "bun update -i",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "check-types": "tsc --noEmit -p tsconfig.isomorphic.json && tsc --noEmit -p tsconfig.browser.json && tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@tanstack/react-query": "5.101.2",
    "@trpc/client": "11.18.0",
    "@trpc/server": "11.18.0",
    "@trpc/tanstack-react-query": "11.18.0",
    "clsx": "2.1.1",
    "react": "19.2.7",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@dither-booth/typescript-config": "workspace:*",
    "@types/bun": "1.3.14",
    "@types/react": "19.2.17"
  }
}
