{
  "name": "@dither-booth/ui",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "imports": {
    "#components/*": "./src/components/*.tsx",
    "#lib/*": "./src/lib/*.tsx",
    "#hooks/*": "./src/hooks/*.tsx"
  },
  "exports": {
    "./components/misc/Webcam": "./src/components/misc/Webcam/index.tsx",
    "./components/ui/*": "./src/components/ui/*.tsx",
    "./components/svg/*": "./src/components/svg/*.tsx",
    "./fields/*": "./src/fields/*/index.tsx",
    "./hooks/user-media": "./src/hooks/user-media/index.tsx",
    "./lib/image-manipulation": "./src/lib/image-manipulation/index.tsx",
    "./lib/hooks/user-media": "./src/lib/hooks/user-media/index.tsx",
    "./lib/utils": "./src/lib/utils.tsx",
    "./lib/formatting": "./src/lib/formatting/index.tsx",
    "./shadcn.css": "./src/styles/shadcn.css"
  },
  "scripts": {
    "update": "bun update -i",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "check-types": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@base-ui/react": "1.5.0",
    "@dither-booth/logging": "workspace:*",
    "@tanstack/react-form": "1.33.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.18.0",
    "next-themes": "0.4.6",
    "shadcn": "4.11.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.1",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
  },
  "peerDependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  }
}
