{
  "name": "dither_booth",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development PROCESS_MANAGER=turborepo turbo run dev -vvv",
    "build": "NODE_ENV=production turbo run build",
    "start": "NODE_ENV=production PROCESS_MANAGER=turborepo turbo run start",
    "pm2:start": "pm2 startOrReload pm2.config.js --env production --update-env",
    "start-pm2:app": "pm2 startOrReload pm2.config.js --env production --update-env --only",
    "pm2:stop": "pm2 stop pm2.config.js",
    "pm2:stop-app": "pm2 stop",
    "pm2:reload": "pm2 reload pm2.config.js --env production --update-env",
    "pm2:reload-app": "pm2 reload --env production --update-env",
    "pm2:delete": "pm2 delete pm2.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:logs-app": "pm2 logs",
    "pm2:save": "pm2 save",
    "pm2:monitor": "pm2 monit",
    "pm2:list": "pm2 list",
    "update": "turbo run update",
    "reinstall-puppeteer": "bun add puppeteer -f -E",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "lint:turbo": "turbo run lint",
    "check-types": "turbo run check-types",
    "devtools": "turbo devtools"
  },
  "dependencies": {
    "bun": "1.3.14",
    "pm2": "7.0.1",
    "puppeteer": "25.1.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "turbo": "2.9.18",
    "typescript": "6.0.3"
  },
  "packageManager": "bun@1.3.13"
}
