{
  "name": "dither_booth",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development turbo run dev -vvv",
    "build": "NODE_ENV=production turbo run build",
    "start": "NODE_ENV=production turbo run start",
    "start:pm2": "pm2 start pm2.config.js",
    "stop:pm2": "pm2 stop pm2.config.js",
    "monitor:pm2": "pm2 monit",
    "list:pm2": "pm2 list",
    "update": "turbo run update",
    "reinstall-puppeteer": "bun add puppeteer -f -E",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "lint:turbo": "turbo run lint",
    "check-types": "turbo run check-types",
    "devtools": "turbo devtools"
  },
  "dependencies": {
    "bun": "1.3.13",
    "pm2": "7.0.1",
    "puppeteer": "24.43.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.13",
    "oxfmt": "0.49.0",
    "oxlint": "1.64.0",
    "turbo": "2.9.12",
    "typescript": "6.0.3"
  },
  "packageManager": "bun@1.3.13"
}
