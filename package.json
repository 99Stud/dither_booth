{
  "name": "dither_booth",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development turbo run dev",
    "start": "NODE_ENV=production turbo run start",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "lint:turbo": "turbo run lint",
    "check-types": "turbo run check-types",
    "devtools": "turbo devtools"
  },
  "devDependencies": {
    "@types/bun": "1.3.13",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "turbo": "2.9.6",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.6"
}
