{
  "name": "dither_booth",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development turbo run dev",
    "dev:public": "NODE_ENV=development MAKE_LOCALLY_ACCESSIBLE=true turbo run dev",
    "start": "NODE_ENV=production turbo run start",
    "start:public": "NODE_ENV=production MAKE_LOCALLY_ACCESSIBLE=true turbo run start",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "lint:turbo": "turbo run lint",
    "check-types": "turbo run check-types",
    "devtools": "turbo devtools"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "prettier": "3.8.1",
    "turbo": "2.9.4",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.6"
}
