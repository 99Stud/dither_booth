{
  "name": "dither_booth",
  "devDependencies": {
    "@types/bun": "1.3.12",
    "oxfmt": "0.45.0",
    "oxlint": "1.60.0",
    "turbo": "2.9.6",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.6",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development turbo run dev",
    "start": "NODE_ENV=production turbo run start",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "lint:turbo": "turbo run lint",
    "check-types": "turbo run check-types",
    "devtools": "turbo devtools"
  },
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
